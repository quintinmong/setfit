# ===================================================================
# 大模型 API 配置 (LLM API Configuration)
# ===================================================================
# 请在此处填写你的 DeepSeek 或 OpenAI API Key
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-pro

# ===================================================================
# 时序训练及模型超参数配置 (Hyperparameters)
# ===================================================================
# 数据增强每类生成的样本目标数
TARGET_COUNT_PER_LABEL=60

# GRU 网络超参数
GRU_INPUT_SIZE=512
GRU_HIDDEN_SIZE=64
GRU_LEARNING_RATE=0.005
GRU_EPOCHS=30
GRU_BATCH_SIZE=4
